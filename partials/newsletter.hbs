<section class="newsletter">

  <div class="container">

    <div class="newsletter__image">
      <img src="{{asset 'images/celso.png'}}" alt="Celso Furtado" />
    </div>

    <div class="newsletter__content">

      <h2 class="newsletter__title">
        Fique por dentro do programa
      </h2>

      <p class="newsletter__description">
        Receba notícias, editais e publicações direto no seu e-mail.
      </p>

    </div>

    <div class="newsletter__form">

      <form>

        <label for="newsletter-email" class="newsletter__label">
          Digite seu e-mail
        </label>

        <div class="newsletter__input-group">

          <input
            id="newsletter-email"
            type="email"
            placeholder="exemplo@email.com"
          />

          <button type="submit" class="newsletter__button">
            Assinar
          </button>

        </div>

      </form>

      <div class="newsletter__privacy">
        🔒 Não compartilhamos seus dados.
      </div>

    </div>

  </div>

</section>