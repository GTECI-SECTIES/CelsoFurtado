<header
  class="header"
  style="
    background: {{@custom.header_color}};
    height: {{@custom.header_height}}px;
  "
>

  <div class="container">

    <div class="header__wrapper">

      <a href="{{@site.url}}" class="header__logo">
        {{#if @site.logo}}
          <img src="{{@site.logo}}" alt="{{@site.title}}" />
        {{/if}}
      </a>

      <nav class="header__nav" id="navMenu">
        {{navigation}}
      </nav>

      <div class="header__actions">

        <button class="gh-search-icon" aria-label="search" data-ghost-search>
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path
              d="M14.949 14.949a1 1 0 0 1 1.414 0l6.344 6.344a1 1 0 0 1-1.414 1.414l-6.344-6.344a1 1 0 0 1 0-1.414Z"
              fill="currentColor"
            />
            <path
              d="M10 3a7 7 0 1 0 0 14 7 7 0 0 0 0-14Zm-9 7a9 9 0 1 1 18 0 9 9 0 0 1-18 0Z"
              fill="currentColor"
            />
          </svg>
        </button>

        <button class="menu-toggle" id="menuToggle">
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
        </button>

      </div>

    </div>

  </div>

</header>

<script src="assets/js/menu.js"></script>
<script src="assets/js/accessibility.js"></script>