<section
  class="about--{{@custom.about_layout}}
    about--img-{{@custom.about_image_style}}
    about--radius-{{@custom.about_image_radius}}
    about--align-{{@custom.about_image_alignment}}
    "
>
  <div class="about">

    <div class="about__content container">
      <div class="about__inner">
        <h2>{{@custom.about_title}}</h2>
        <p>{{@custom.about_description}}</p>
      </div>
    </div>

    <div class="about__image">
      {{#if @custom.about_image}}
        <img src="{{@custom.about_image}}" alt="{{@custom.about_title}}" />
      {{/if}}
    </div>

  </div>
</section>