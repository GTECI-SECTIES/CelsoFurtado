
{{#if @custom.hero_section}}

<section class="hero hero--{{@custom.hero_logo_position}}">
  <div
    class="hero__overlay"
    {{#if @site.cover_image}}
      style="background-image: url('{{@site.cover_image}}');"
    {{/if}}
  ></div>

  <div class="hero__content container">

    {{#match @custom.hero_logo_position "nav"}}
      {{!-- não mostra --}}
    {{else}}
      {{#match @custom.hero_logo_position "hidden"}}
        {{!-- não mostra --}}
      {{else}}
        {{#if @custom.hero_logo}}
          <img src="{{@custom.hero_logo}}" alt="logo" class="hero__logo" />
        {{/if}}
      {{/match}}
    {{/match}}

    <h1>{{@site.title}}</h1>
    <p>{{@site.description}}</p>

  </div>
</section>
{{/if}}
